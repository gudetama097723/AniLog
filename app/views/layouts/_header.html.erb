<header>
  <nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom">
    <div class="container">
      <%= link_to "AniLog", root_path, class: "navbar-brand fw-bold" %>

      <ul class="navbar-nav ms-auto">
        <li class="nav-item">
          <%= link_to "Top", root_path, class: "nav-link" %>
        </li>

        <li class="nav-item">
          <%= link_to "About", about_path, class: "nav-link" %>
        </li>

        <% if authenticated? %>
          <li class="nav-item">
            <%= link_to "ログアウト", session_path, data: { turbo_method: :delete }, class: "nav-link" %>
          </li>
        <% else %>
          <li class="nav-item">
            <%= link_to "ログイン", new_session_path, class: "nav-link" %>
          </li>

          <li class="nav-item">
            <%= link_to "新規登録", new_user_path, class: "nav-link" %>
          </li>
        <% end %>
      </ul>
    </div>
  </nav>
</header>