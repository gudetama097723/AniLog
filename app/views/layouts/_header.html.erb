<header class="sticky-top">
  <nav class="navbar navbar-expand-lg bg-white border-bottom shadow-sm">
    <div class="container">
      <%= link_to root_path, class: "navbar-brand d-flex align-items-center" do %>
        <%= image_tag "logo.png", height: 70, class: "me-2" %>
      <% end %>

      <ul class="navbar-nav ms-auto align-items-center gap-2">
        <li class="nav-item">
          <%= link_to "Top", root_path, class: "nav-link fw-semibold" %>
        </li>

        <% if authenticated? %>
          <li class="nav-item">
            <%= link_to "マイページ", mypage_path, class: "nav-link fw-semibold" %>
          </li>

          <li class="nav-item">
            <%= link_to "投稿一覧", anime_reviews_path, class: "nav-link fw-semibold" %>
          </li>

          <li class="nav-item">
            <%= link_to "ユーザー一覧", users_path, class: "nav-link fw-semibold" %>
          </li>

          <li class="nav-item">
            <%= link_to "新規投稿", new_anime_review_path, class: "nav-link fw-semibold" %>
          </li>

          <li class="nav-item">
            <%= link_to "ログアウト", session_path,
                data: { turbo_method: :delete },
                class: "btn btn-outline-primary rounded-pill px-3" %>
          </li>
        <% else %>
          <li class="nav-item">
            <%= link_to "About", about_path, class: "nav-link fw-semibold" %>
          </li>

          <li class="nav-item">
            <%= link_to "ログイン", new_session_path, class: "nav-link fw-semibold" %>
          </li>

          <li class="nav-item">
            <%= link_to "新規登録", new_user_path, class: "btn btn-primary rounded-pill px-3" %>
          </li>
        <% end %>
      </ul>
    </div>
  </nav>

  <% if authenticated? %>
    <div class="bg-light border-bottom">
      <div class="container py-3">
        <%= form_with url: search_path, method: :get, local: true do |f| %>
          <div class="d-flex gap-2">
            <%= f.select :target,
                [["投稿", "anime_reviews"], ["ユーザー", "users"]],
                {},
                class: "form-select w-auto" %>

            <%= f.text_field :keyword,
                placeholder: "キーワードを入力",
                class: "form-control" %>

            <%= f.submit "検索",
                class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</header>