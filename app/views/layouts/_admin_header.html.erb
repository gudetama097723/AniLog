<header>
  <nav class="navbar navbar-expand-lg bg-dark border-bottom">
    <div class="container">
      <%= link_to "AniLog Admin", admin_sign_in_path, class: "navbar-brand text-white" %>

      <div class="ms-auto">
        <% if session[:admin_id].present? %>
          <%= link_to "管理者ログアウト",
              admin_sign_out_path,
              data: { turbo_method: :delete },
              class: "btn btn-outline-light" %>
        <% else %>
          <%= link_to "ユーザーとしてログイン",
              new_session_path,
              class: "btn btn-outline-light" %>
        <% end %>
      </div>
    </div>
  </nav>
</header>