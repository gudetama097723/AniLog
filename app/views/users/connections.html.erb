<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 fw-bold mb-0"><%= @user.name %>さんのつながり</h1>

  <% if @user == Current.user %>
    <%= link_to "マイページへ戻る",
        mypage_path,
        class: "btn btn-outline-secondary btn-sm" %>
  <% else %>
    <%= link_to "ユーザー詳細へ戻る",
        user_path(@user),
        class: "btn btn-outline-secondary btn-sm" %>
  <% end %>
</div>

<ul class="nav nav-tabs mb-4">
  <li class="nav-item">
    <%= link_to connections_user_path(@user, tab: "following"),
        class: "nav-link #{@tab == 'following' ? 'active' : ''}" do %>
      フォロー <%= @user.following.count %>
    <% end %>
  </li>

  <li class="nav-item">
    <%= link_to connections_user_path(@user, tab: "followers"),
        class: "nav-link #{@tab == 'followers' ? 'active' : ''}" do %>
      フォロワー <%= @user.followers.count %>
    <% end %>
  </li>
</ul>

<% if @users.any? %>
  <%= render "user_list", users: @users %>
<% else %>
  <div class="alert alert-secondary">
    該当するユーザーはいません。
  </div>
<% end %>