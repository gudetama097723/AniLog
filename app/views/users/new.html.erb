<div class="row justify-content-center">
  <div class="col-md-7 col-lg-5">
    <div class="card shadow-sm border-0">
      <div class="card-body p-4 p-md-5">
        <div class="text-center mb-4">
          <h1 class="h3 fw-bold mb-2">新規登録</h1>
          <p class="text-muted mb-0">AniLogでアニメレビューを始めましょう!</p>
        </div>

        <% if @user.errors.any? %>
          <div class="alert alert-danger">
            <ul class="mb-0">
              <% @user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= form_with model: @user, url: users_path do |f| %>
          <div class="mb-3">
            <%= f.label :name, "ユーザー名", class: "form-label" %>
            <%= f.text_field :name, class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= f.label :email_address, "メールアドレス", class: "form-label" %>
            <%= f.email_field :email_address, class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= f.label :password, "パスワード", class: "form-label" %>
            <%= f.password_field :password, class: "form-control" %>
          </div>

          <div class="mb-4">
            <%= f.label :password_confirmation, "パスワード確認", class: "form-label" %>
            <%= f.password_field :password_confirmation, class: "form-control" %>
          </div>

          <div class="d-grid mb-3">
            <%= f.submit "新規登録", class: "btn btn-primary" %>
          </div>
        <% end %>

        <div class="text-center">
          <%= link_to "すでにアカウントをお持ちの方", new_session_path, class: "link-secondary small" %>
        </div>
      </div>
    </div>
  </div>
</div>