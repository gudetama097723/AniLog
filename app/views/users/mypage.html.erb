<div class="row g-4">
  <div class="col-md-4 col-lg-3">
    <div class="card shadow-sm border-0">
      <div class="card-body text-center">
        <% if @user.image.attached? %>
          <%= image_tag @user.image, class: "profile-image mb-3" %>
        <% else %>
          <%= image_tag "no_image.png", class: "profile-image mb-3" %>
        <% end %>

        <h2 class="h5 fw-bold mb-2"><%= @user.name %></h2>

        <p class="text-muted small mb-3">
          <%= @user.introduction.presence || "自己紹介はまだありません。" %>
        </p>

        <div class="d-grid gap-2">
          <%= link_to "プロフィール編集", edit_user_path(@user), class: "btn btn-primary btn-sm rounded-pill" %>
          <%= link_to "退会", user_path(@user),
              data: { turbo_method: :delete, turbo_confirm: "本当に退会しますか？" },
              class: "btn btn-outline-danger btn-sm rounded-pill" %>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-8 col-lg-9">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="h3 mb-0">マイページ</h1>
      <span class="badge bg-primary rounded-pill">
        投稿 <%= @anime_reviews.count %>件
      </span>
    </div>

    <h2 class="h5 mb-3">自分の投稿一覧</h2>

    <% if @anime_reviews.any? %>
      <% @anime_reviews.each do |anime_review| %>
        <div class="card mb-3 shadow-sm border-0">
          <div class="card-body">
            <h3 class="h5 card-title fw-bold">
              <%= anime_review.title %>
            </h3>

            <p class="card-text text-muted">
              <%= truncate(anime_review.body, length: 120) %>
            </p>

            <%= link_to "詳細を見る", anime_review_path(anime_review),
                class: "btn btn-outline-primary btn-sm rounded-pill" %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
          <p class="text-muted mb-3">まだ投稿がありません。</p>
          <%= link_to "レビューを投稿する", new_anime_review_path,
              class: "btn btn-primary rounded-pill px-4" %>
        </div>
      </div>
    <% end %>
  </div>
</div>