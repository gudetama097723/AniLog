<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>マイページ</h1>

  <div>
    <%= link_to "編集", edit_user_path(@user), class: "btn btn-primary" %>
    <%= link_to "退会", user_path(@user),
        data: { turbo_method: :delete, turbo_confirm: "本当に退会しますか？" },
        class: "btn btn-danger" %>
  </div>
</div>

<p>ユーザー名: <%= @user.name %></p>
<p>メールアドレス: <%= @user.email_address %></p>

<h2 class="h4 mt-5 mb-3">自分の投稿一覧</h2>

<% @anime_reviews.each do |anime_review| %>
  <div class="card mb-3">
    <div class="card-body">
      <h3 class="h5 card-title"><%= anime_review.title %></h3>
      <p class="card-text"><%= anime_review.body %></p>
      <%= link_to "詳細を見る", anime_review_path(anime_review), class: "btn btn-outline-primary btn-sm" %>
    </div>
  </div>
<% end %>