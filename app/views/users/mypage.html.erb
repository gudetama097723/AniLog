<div class="row g-4">
  <div class="col-md-4 col-lg-3">
    <div class="card shadow-sm border-0">
      <div class="card-body text-center">
        <% if @user.image.attached? %>
          <%= image_tag @user.image, class: "profile-image mb-3" %>
        <% else %>
          <%= image_tag "no_image.png", class: "profile-image mb-3" %>
        <% end %>

        <h2 class="h5 fw-bold mb-2"><%= @user.name %></h2>

        <p class="text-muted small mb-3">
          <%= @user.introduction.presence || "自己紹介はまだありません。" %>
        </p>

        <div class="d-flex justify-content-center gap-2 mb-4">
          <%= link_to connections_user_path(@user, tab: "following"),
              class: "btn btn-sm btn-light border text-dark px-3 rounded-2" do %>
            <span class="text-muted">フォロー</span>
            <strong class="ms-1"><%= @user.following.count %></strong>
          <% end %>

          <%= link_to connections_user_path(@user, tab: "followers"),
              class: "btn btn-sm btn-light border text-dark px-3 rounded-2" do %>
            <span class="text-muted">フォロワー</span>
            <strong class="ms-1"><%= @user.followers.count %></strong>
          <% end %>
        </div>

        <div class="d-grid gap-2">
          <%= link_to "プロフィール編集", edit_user_path(@user), class: "btn btn-primary btn-sm rounded-pill" %>
          <%= link_to "退会", user_path(@user),
              data: { turbo_method: :delete, turbo_confirm: "本当に退会しますか？" },
              class: "btn btn-outline-danger btn-sm rounded-pill" %>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-8 col-lg-9">
    <div class="d-flex justify-content-between align-items-end mb-4">
      <h1 class="h3 fw-bold mb-1">マイページ</h1>

      <div class="text-end <%= 'invisible' unless @tab == 'mine' %>">
        <div class="display-6 fw-bold text-dark lh-1">
          <%= @user.anime_reviews.count %>件
        </div>

        <div class="text-muted small mt-1">
          総視聴レビュー数
        </div>
      </div>
    </div>

    <ul class="nav nav-tabs mb-4">
      <li class="nav-item">
        <%= link_to "自分の投稿",
            mypage_path(tab: "mine"),
            class: "nav-link #{@tab == 'mine' ? 'active' : ''}" %>
      </li>

      <li class="nav-item">
        <%= link_to "フォロー中の投稿",
            mypage_path(tab: "following"),
            class: "nav-link #{@tab == 'following' ? 'active' : ''}" %>
      </li>
    </ul>

    <% if @anime_reviews.any? %>
      <% @anime_reviews.each do |anime_review| %>
        <div class="card mb-3 shadow-sm border-0 rounded-3">
          <div class="card-body">
            <% if @tab == "following" %>
              <div class="d-flex gap-3 mb-3">
                <div class="text-center flex-shrink-0" style="width: 80px;">

                  <% if anime_review.user.image.attached? %>
                    <%= image_tag anime_review.user.image,class: "profile-image-sm mb-2" %>
                  <% else %>
                    <%= image_tag "no_image.png",class: "profile-image-sm mb-2" %>
                  <% end %>

                  <span class="d-block small fw-semibold text-dark text-break">
                    <%= anime_review.user.name %>
                  </span>
                </div>

                <div class="flex-grow-1 min-w-0">
                  <h3 class="h6 fw-bold mb-2">
                    <%= anime_review.title %>
                  </h3>

                  <p class="text-muted small mb-0">
                    <%= truncate(anime_review.body, length: 100) %>
                  </p>
                </div>
              </div>
            <% else %>
              <h3 class="h5 card-title fw-bold">
                <%= anime_review.title %>
              </h3>

              <p class="card-text text-muted">
            <%= truncate(anime_review.body, length: 120) %>
              </p>
            <% end %>

            <div class="d-flex justify-content-between align-items-center mb-3">
              <div class="d-flex align-items-center gap-3">
                <p class="mb-0">評価: ⭐ <%= anime_review.rating %> / 5</p>
                <%= link_to "詳細を見る", anime_review_path(anime_review, return_to: request.fullpath),class: "btn btn-outline-primary btn-sm rounded-pill" %>
              </div>

              <div class="text-muted small">
                <%= anime_review.created_at.strftime("%Y年%-m月%-d日 %H:%M") %>
              </div>
            </div>
          </div>
        </div>
      <% end %>

    <% else %>

      <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
          <p class="text-muted mb-3">まだ投稿がありません。</p>
          <%= link_to "レビューを投稿する", new_anime_review_path, class: "btn btn-primary rounded-pill px-4" %>
        </div>
      </div>
    <% end %>
  </div>
</div>