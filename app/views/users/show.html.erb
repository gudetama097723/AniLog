<% if params[:return_to].present? %>
  <div class="mb-3">
    <%= link_to "レビュー詳細へ戻る",
        params[:return_to],
        class: "btn btn-outline-secondary btn-sm" %>
  </div>
<% end %>

<div class="row g-4">
  <div class="col-md-4 col-lg-3">
    <div class="card shadow-sm border-0 rounded-3">
      <div class="card-body text-center">
        <% if @user.image.attached? %>
          <%= image_tag @user.image, class: "profile-image mb-3" %>
        <% else %>
          <%= image_tag "no_image.png", class: "profile-image mb-3" %>
        <% end %>

        <h1 class="h5 fw-bold mb-2">
          <%= @user.name %>
        </h1>

        <p class="text-muted small mb-4">
          <%= @user.introduction.presence || "自己紹介はまだありません。" %>
        </p>

        <div class="d-flex flex-wrap justify-content-center gap-2 mb-4">
          <%= link_to connections_user_path(@user, tab: "following"),
              class: "btn btn-sm btn-light border text-dark px-3 rounded-2" do %>
            <span class="text-muted">フォロー</span>
            <strong class="ms-1"><%= @user.following.count %></strong>
          <% end %>

          <%= link_to connections_user_path(@user, tab: "followers"),
              class: "btn btn-sm btn-light border text-dark px-3 rounded-2" do %>
            <span class="text-muted">フォロワー</span>
            <strong class="ms-1"><%= @user.followers.count %></strong>
          <% end %>
        </div>

        <div class="border-top pt-3 mb-4">
          <div class="row g-2 text-center">
            <div class="col-6">
              <div class="fw-bold"><%= @anime_reviews.size %></div>
              <div class="text-muted small">レビュー</div>
            </div>

            <div class="col-6">
              <div class="fw-bold"><%= @user.comments.count %></div>
              <div class="text-muted small">コメント</div>
            </div>
          </div>
        </div>

        <% if @user == Current.user %>
          <div class="d-grid">
            <%= link_to "プロフィール編集",
                edit_user_path(@user),
                class: "btn btn-outline-primary btn-sm rounded-pill" %>
          </div>
        <% elsif Current.user.following?(@user) %>
          <% relationship =
            Current.user.active_relationships.find_by(followed_id: @user.id) %>

          <div class="d-grid">
            <%= button_to "フォロー解除",
                relationship_path(relationship),
                method: :delete,
                class: "btn btn-outline-danger btn-sm rounded-pill w-100" %>
          </div>
        <% else %>
          <div class="d-grid">
            <%= button_to "フォローする",
                relationships_path,
                params: { followed_id: @user.id },
                method: :post,
                class: "btn btn-primary btn-sm rounded-pill w-100" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-8 col-lg-9">
    <div class="d-flex justify-content-between align-items-end mb-4">
      <div>
        <h2 class="h3 fw-bold mb-1">投稿一覧</h2>
        <p class="text-muted mb-0">
          <%= @user.name %>さんのレビュー
        </p>
      </div>

      <div class="text-end">
        <div class="display-6 fw-bold text-dark lh-1">
          <%= @anime_reviews.size %>件
        </div>
        <div class="text-muted small mt-1">
          総レビュー数
        </div>
      </div>
    </div>

    <% if @anime_reviews.any? %>
      <% @anime_reviews.each do |anime_review| %>
        <div class="card mb-3 shadow-sm border-0 rounded-3">
          <div class="card-body">
            <div class="d-flex justify-content-between gap-3 mb-2">
              <h3 class="h5 fw-bold mb-0">
                <%= anime_review.title %>
              </h3>

              <span class="badge text-bg-secondary align-self-start">
                <%= anime_review.genre&.name || "未設定" %>
              </span>
            </div>

            <p class="text-muted mb-3">
              <%= truncate(anime_review.body, length: 120) %>
            </p>

            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
              <div class="d-flex align-items-center gap-3">
                <span>
                  評価: ⭐ <%= anime_review.rating %> / 5
                </span>

                <%= link_to "詳細を見る",
                    anime_review_path(
                      anime_review,
                      return_to: request.fullpath
                    ),
                    class: "btn btn-outline-primary btn-sm rounded-pill" %>
              </div>

              <div class="text-muted small">
                <%= anime_review.created_at.strftime("%Y年%-m月%-d日 %H:%M") %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body text-center py-5">
          <p class="text-muted mb-0">
            まだレビューがありません。
          </p>
        </div>
      </div>
    <% end %>
  </div>
</div>