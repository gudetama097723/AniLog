<h1 class="mb-4">ユーザー一覧</h1>

<% @users.each do |user| %>
  <div class="card mb-3">
    <div class="card-body d-flex align-items-center gap-3">
      <% if user.image.attached? %>
        <%= image_tag user.image, class: "profile-image-sm" %>
      <% else %>
        <%= image_tag "no_image.png", class: "profile-image-sm" %>
      <% end %>

      <div>
        <h2 class="h5 mb-1"><%= user.name %></h2>
        <%= link_to "詳細を見る", user_path(user), class: "btn btn-outline-primary btn-sm" %>
      </div>
    </div>
  </div>
<% end %>