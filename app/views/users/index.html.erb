<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 fw-bold mb-1">ユーザー一覧</h1>
    <p class="text-muted mb-0">気になるユーザーのレビューを見に行けます。</p>
  </div>
  <%= form_with url: users_path, method: :get, local: true, class: "d-flex gap-2" do |f| %>
    <%= f.select :sort,
        [
          ["新規登録順", "newest"],
          ["参考にされた順", "helpful"],
          ["フォロワー数順", "followers"]
        ],
        { selected: @sort },
        class: "form-select form-select-sm" %>

    <%= f.submit "並び替え", class: "btn btn-outline-primary btn-sm" %>
  <% end %>
</div>

<%= render "user_list", users: @users %>