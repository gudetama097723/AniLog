<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 fw-bold mb-1">ユーザー一覧</h1>
    <p class="text-muted mb-0">気になるユーザーのレビューを見に行けます。</p>
  </div>
</div>

<div class="vstack gap-3">
  <% @users.each do |user| %>
    <div class="card shadow-sm border-0 rounded-3">
      <div class="card-body d-flex align-items-center gap-3">
        <% if user.image.attached? %>
          <%= image_tag user.image, class: "profile-image-sm" %>
        <% else %>
          <%= image_tag "no_image.png", class: "profile-image-sm" %>
        <% end %>

        <div class="flex-grow-1 min-w-0">
          <h2 class="h5 fw-bold mb-1 text-truncate"><%= user.name %></h2>
          <p class="text-muted small mb-0">
            レビュー <%= user.anime_reviews.size %>件
          </p>
        </div>

        <%= link_to "詳細を見る",
            user_path(user),
            class: "btn btn-outline-primary btn-sm flex-shrink-0" %>
      </div>
    </div>
  <% end %>
</div>