<div class="vstack gap-3">
  <% @users.each do |user| %>
    <div class="card shadow-sm border-0 rounded-3">
      <div class="card-body d-flex align-items-center gap-3">
        <% if user.image.attached? %>
          <%= image_tag user.image, class: "profile-image-sm" %>
        <% else %>
          <%= image_tag "no_image.png", class: "profile-image-sm" %>
        <% end %>

        <div class="flex-grow-1 min-w-0">
          <h3 class="h5 fw-bold mb-1 text-truncate"><%= user.name %></h3>

          <p class="text-muted small mb-1">
            <%= truncate(user.introduction.presence || "自己紹介は未設定です。", length: 80) %>
          </p>

          <div class="d-flex flex-wrap gap-3 small text-muted">
            <span>
              レビュー <strong class="text-dark"><%= user.anime_reviews.size %></strong>件
            </span>

            <span>
              参考にされた総数 <strong class="text-dark"><%= user.anime_reviews.sum(:helpful_reviews_count) %></strong>件
            </span>
          </div>
        </div>

        <div class="d-flex flex-wrap align-items-center gap-2 flex-shrink-0">
          <div class="border rounded-2 bg-light px-3 py-1 small text-nowrap">
            <span class="text-muted">フォロー</span>
            <strong class="ms-1"><%= user.following.count %></strong>
          </div>

          <div class="border rounded-2 bg-light px-3 py-1 small text-nowrap">
            <span class="text-muted">フォロワー</span>
            <strong class="ms-1"><%= user.followers.count %></strong>
          </div>
        </div>

        <%= link_to "詳細を見る",
            user_path(user),
            class: "btn btn-outline-primary btn-sm flex-shrink-0" %>
      </div>
    </div>
  <% end %>
</div>