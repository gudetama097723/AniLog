<div class="mb-4">
  <%= link_to "前の画面へ戻る", params[:return_to].presence || anime_reviews_path, class: "btn btn-outline-secondary btn-sm" %>
</div>

<div class="card shadow-sm border-0 rounded-3 mb-4">
  <div class="card-body p-4">
    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
      <div>
        <h1 class="h3 fw-bold mb-2"><%= @anime_review.title %></h1>

        <div class="d-flex flex-wrap gap-2 align-items-center text-muted small">
          <%= link_to @anime_review.user.name, user_path(@anime_review.user, return_to: request.fullpath), class: "text-decoration-none fw-semibold" %>
          <span>評価: ⭐ <%= @anime_review.rating %> / 5</span>
          <span class="badge text-bg-secondary">
            <%= @anime_review.genre&.name || "未設定" %>
          </span>
        </div>
      </div>

      <% if @anime_review.user == Current.user %>
        <div class="d-flex gap-2">
          <%= link_to "編集", edit_anime_review_path(@anime_review), class: "btn btn-outline-primary btn-sm" %>
          <%= link_to "削除", anime_review_path(@anime_review),
              data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" },
              class: "btn btn-outline-danger btn-sm" %>
        </div>
      <% end %>
    </div>

    <div class="border-top pt-3">
      <%= simple_format(@anime_review.body, class: "mb-0") %>
    </div>
  </div>
</div>

<div class="card shadow-sm border-0 rounded-3 mb-4">
  <div class="card-body p-4">
    <h2 class="h5 fw-bold mb-3">コメント</h2>

    <% if @comments.any? %>
      <div class="vstack gap-3 mb-4">
        <% @comments.each do |comment| %>
          <div class="border rounded-3 p-3">
            <div class="d-flex justify-content-between align-items-start gap-3">
              <div class="d-flex align-items-start gap-2">
                <% if comment.user.image.attached? %>
                  <%= image_tag comment.user.image, class: "comment-user-icon flex-shrink-0" %>
                <% else %>
                  <%= image_tag "no_image.png", class: "comment-user-icon flex-shrink-0" %>
                <% end %>
                <div>
                  <p class="mb-1">
                    <%= link_to comment.user.name,user_path(comment.user, return_to: request.fullpath), class: "fw-semibold text-decoration-none text-dark" %>
                  </p>
                  <%= simple_format(comment.body, class: "mb-0 text-muted") %>
                </div>
              </div>

              <% if comment.user == Current.user %>
                <%= link_to "削除",
                    anime_review_comment_path(@anime_review, comment),
                    data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" },
                    class: "btn btn-outline-danger btn-sm" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-muted mb-4">まだコメントはありません。</p>
    <% end %>

    <%= form_with model: [@anime_review, Comment.new] do |f| %>
      <div class="mb-3">
        <%= f.text_area :body,
            rows: 3,
            placeholder: "コメントを書く",
            class: "form-control" %>
      </div>

      <%= f.submit "送信", class: "btn btn-primary" %>
    <% end %>
  </div>
</div>