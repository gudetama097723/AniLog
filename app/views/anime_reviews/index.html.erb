<div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
  <div>
    <h1 class="h3 fw-bold mb-1">投稿一覧</h1>
    <p class="text-muted mb-0">気になるレビューを探してみましょう。</p>
  </div>

  <div class="d-flex flex-wrap align-items-center gap-2">
    <%= form_with url: anime_reviews_path, method: :get, local: true, class: "d-flex gap-2" do |f| %>
      <%= f.select :sort,
          [
            ["新着順", "newest"],
            ["評価順", "rating"],
            ["参考になった順", "helpful"],
            ["コメント件数順", "comments"]
          ],
          { selected: @sort },
          class: "form-select form-select-sm" %>

      <%= f.submit "並び替え", class: "btn btn-outline-primary btn-sm" %>
    <% end %>

    <%= link_to "新規投稿",
        new_anime_review_path,
        class: "btn btn-primary btn-sm rounded-pill px-3" %>
  </div>
</div>

<div class="row g-3">
  <% @anime_reviews.each do |anime_review| %>
    <div class="col-md-6 col-lg-4">
      <div class="card h-100 shadow-sm border-0 rounded-3 position-relative">
        <div class="card-body d-flex flex-column">

          <div class="d-flex align-items-center mb-3">
            <% if anime_review.user.image.attached? %>
              <%= image_tag anime_review.user.image,
                  class: "review-user-icon me-2" %>
            <% else %>
              <%= image_tag "no_image.png",
                  class: "review-user-icon me-2" %>
            <% end %>

            <div class="min-w-0">
              <div class="fw-semibold small text-truncate">
                <%= anime_review.user.name %>
              </div>

              <small class="text-muted">
                <%= anime_review.created_at.strftime("%Y年%-m月%-d日 %H:%M") %>
              </small>
            </div>
          </div>

          <h2 class="h6 fw-bold mb-2">
            <%= link_to anime_review.title,
                anime_review_path(anime_review),
                class: "stretched-link text-decoration-none text-dark" %>
          </h2>

          <div class="mb-2">
            <span class="badge text-bg-secondary">
              <%= anime_review.genre&.name || "未設定" %>
            </span>
          </div>

          <p class="text-muted small mb-3">
            <%= truncate(anime_review.body, length: 80) %>
          </p>

          <div class="mt-auto d-flex justify-content-between align-items-center small text-muted">
            <span>⭐ <%= anime_review.rating %> / 5</span>
            <span>参考になった <strong><%= anime_review.helpful_reviews_count %></strong>件</span>
            <span>コメント <%= anime_review.comments_count %>件</span>
          </div>

        </div>
      </div>
    </div>
  <% end %>
</div>