<% if anime_review.errors.any? %>
  <div class="alert alert-danger">
    <ul class="mb-0">
      <% anime_review.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: anime_review do |f| %>
  <div class="mb-3">
    <%= f.label :title, "タイトル", class: "form-label" %>
    <%= f.text_field :title, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :body, "本文", class: "form-label" %>
    <%= f.text_area :body, class: "form-control", rows: 5 %>
  </div>

  <div class="mb-3">
    <%= f.label :rating, "評価", class: "form-label" %>
    <%= f.number_field :rating, class: "form-control", min: 1, max: 5 %>
  </div>

  <%= f.submit class: "btn btn-primary" %>
<% end %>