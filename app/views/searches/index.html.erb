<div class="mb-4">
  <h1 class="h3 fw-bold mb-2">検索結果</h1>

  <div class="d-flex flex-wrap gap-2 align-items-center text-muted">
    <span>
      検索対象:
      <span class="badge text-bg-secondary">
        <%= @target == "users" ? "ユーザー" : "投稿" %>
      </span>
    </span>

    <span>
      キーワード:
      <span class="fw-semibold text-dark"><%= @keyword.presence || "未入力" %></span>
    </span>
  </div>
</div>

<% if @target == "anime_reviews" %>
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
      <h2 class="h5 fw-bold mb-0">投稿の検索結果</h2>
      <span class="text-muted small"><%= @anime_reviews.size %>件</span>
    </div>

    <%= form_with url: search_path, method: :get, local: true, class: "d-flex gap-2" do |f| %>
      <%= f.hidden_field :target, value: @target %>
      <%= f.hidden_field :keyword, value: @keyword %>

      <%= f.select :sort,
          [
            ["新着順", "newest"],
            ["評価順", "rating"],
            ["参考になった順", "helpful"],
            ["コメント件数順", "comments"]
          ],
          { selected: @sort },
          class: "form-select form-select-sm" %>

      <%= f.submit "並び替え", class: "btn btn-outline-primary btn-sm" %>
    <% end %>
  </div>

  <% if @anime_reviews.any? %>
    <div class="row g-3">
      <% @anime_reviews.each do |anime_review| %>
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 shadow-sm border-0 rounded-3 position-relative">
            <div class="card-body d-flex flex-column">
              <h3 class="h6 fw-bold mb-2">
                <%= link_to anime_review.title,
                    anime_review_path(anime_review),
                    class: "stretched-link text-decoration-none text-dark" %>
              </h3>

              <div class="mb-2">
                <span class="badge text-bg-secondary">
                  <%= anime_review.genre&.name || "未設定" %>
                </span>
              </div>

              <p class="text-muted small mb-3">
                <%= truncate(anime_review.body, length: 80) %>
              </p>

              <div class="mt-auto d-flex justify-content-between align-items-center small text-muted">
                <span>⭐ <%= anime_review.rating %> / 5</span>
                <span><%= anime_review.user.name %></span>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="alert alert-secondary">
      該当する投稿はありません。
    </div>
  <% end %>
<% elsif @target == "users" %>
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
      <h2 class="h5 fw-bold mb-0">ユーザーの検索結果</h2>
      <span class="text-muted small"><%= @users.size %>件</span>
    </div>

    <%= form_with url: search_path, method: :get, local: true, class: "d-flex gap-2" do |f| %>
      <%= f.hidden_field :target, value: @target %>
      <%= f.hidden_field :keyword, value: @keyword %>

      <%= f.select :sort,
          [
            ["新規登録順", "newest"],
            ["参考にされた順", "helpful"],
            ["フォロワー数順", "followers"]
          ],
          { selected: @sort },
          class: "form-select form-select-sm" %>

      <%= f.submit "並び替え", class: "btn btn-outline-primary btn-sm" %>
    <% end %>
  </div>

  <% if @users.any? %>
    <%= render "users/user_list", users: @users %>
  <% else %>
    <div class="alert alert-secondary">
      該当するユーザーはありません。
    </div>
  <% end %>
<% end %>