<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1">レビュー管理</h1>
    <p class="text-muted mb-0">投稿されたレビューの確認と削除を行います。</p>
  </div>
</div>

<div class="card shadow-sm border-0">
  <div class="card-body p-0">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>ID</th>
          <th>タイトル</th>
          <th>投稿者</th>
          <th>ジャンル</th>
          <th>評価</th>
          <th>投稿日</th>
          <th class="text-end">操作</th>
        </tr>
      </thead>

      <tbody>
        <% @anime_reviews.each do |anime_review| %>
          <tr>
            <td><%= anime_review.id %></td>
            <td class="fw-semibold"><%= anime_review.title %></td>
            <td><%= anime_review.user.name %></td>
            <td>
              <span class="badge text-bg-secondary">
                <%= anime_review.genre&.name || "未設定" %>
              </span>
            </td>
            <td><%= anime_review.rating %></td>
            <td><%= l anime_review.created_at, format: :short %></td>
            <td class="text-end">
              <%= link_to "詳細",
                  admin_anime_review_path(anime_review),
                  class: "btn btn-outline-primary btn-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>