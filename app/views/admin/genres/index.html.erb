<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1">ジャンル管理</h1>
    <p class="text-muted mb-0">レビュー投稿時に選択できるジャンルを管理します。</p>
  </div>
</div>

<div class="card shadow-sm border-0 mb-4">
  <div class="card-body">
    <h2 class="h5 mb-3">ジャンル追加</h2>

    <%= form_with model: [:admin, @genre], local: true, class: "row g-2" do |f| %>
      <div class="col-md-9">
        <%= f.text_field :name,
            placeholder: "ジャンル名",
            class: "form-control" %>
      </div>

      <div class="col-md-3 d-grid">
        <%= f.submit "追加", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>

<div class="card shadow-sm border-0">
  <div class="card-body p-0">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>ID</th>
          <th>ジャンル名</th>
          <th>作成日</th>
          <th class="text-end">操作</th>
        </tr>
      </thead>

      <tbody>
        <% @genres.each do |genre| %>
          <tr>
            <td><%= genre.id %></td>
            <td>
              <%= form_with model: [:admin, genre], local: true, class: "d-flex gap-2" do |f| %>
                <%= f.text_field :name, class: "form-control form-control-sm" %>
                <%= f.submit "更新", class: "btn btn-outline-primary btn-sm" %>
              <% end %>
            </td>
            <td><%= l genre.created_at, format: :short %></td>
            <td class="text-end">
              <%= link_to "削除",
                  admin_genre_path(genre),
                  data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" },
                  class: "btn btn-outline-danger btn-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>