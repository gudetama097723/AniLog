<div class="row justify-content-center">
  <div class="col-md-6 col-lg-4">
    <div class="card shadow-sm border-0">
      <div class="card-body p-4">
        <h1 class="h3 mb-4 text-center">管理者ログイン</h1>

        <%= form_with url: admin_sign_in_path, local: true do |f| %>
          <div class="mb-3">
            <%= f.label :login_id, "ID", class: "form-label" %>
            <%= f.text_field :login_id, class: "form-control", autofocus: true %>
          </div>

          <div class="mb-4">
            <%= f.label :password, "パスワード", class: "form-label" %>
            <%= f.password_field :password, class: "form-control" %>
          </div>

          <div class="d-grid">
            <%= f.submit "ログイン", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>